/*!
  \page examples_libm Lib Math benchmarks

  The Lib Math benchmark suite tests the support for each one of the math functions available in the LibM for the single-precision implementation.

  Here is the list of tested functions:
  \verbatim
  acosf
  acoshf
  asinf
  asinhf
  atan2f
  atanf
  atanhf
  cbrtf
  ceilf
  cosf
  coshf
  erfcf
  erff
  expf
  expm1f
  floorf
  fmodf
  tgammaf
  hypotf
  ilogbf
  ldexpf
  log10f
  log1pf
  logbf
  logf
  powf
  remainderf
  rintfscalbnf
  significandf
  sinf
  sinhf
  sqrtf
  tanf
  tanhf
  \endverbatim


*/
