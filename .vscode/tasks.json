{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "Build dev",
         "type": "shell",
         "command": "make",
         "args": [
            "install",
            "CONFIGURE_FLAGS=\"--prefix=${workspaceFolder}/panda_dist --enable-opt --with-opt-level=2 --disable-release --enable-Werror\"",
            "-j8"
         ],
         "problemMatcher": "$gcc",
         "group": {
            "kind": "build"
         }
      },
      {
         "label": "Build release",
         "type": "shell",
         "command": "make",
         "args": [
            "install",
            "CONFIGURE_FLAGS=\"--prefix=${workspaceFolder}/panda_dist --enable-opt --with-opt-level=2 --enable-release --disable-asserts --enable-Werror\"",
            "-j8"
         ],
         "problemMatcher": "$gcc",
         "group": {
            "kind": "build",
            "isDefault": true
         }
      }
   ]
}
