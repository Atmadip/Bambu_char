{
   "version": "2.0.0",
   "tasks": [
      {
         "label": "CMake Configure Release",
         "type": "shell",
         "command": "cmake",
         "args": [
            "-S",
            ".",
            "-B",
            "build",
            "-DCMAKE_BUILD_TYPE=Release",
            "-DCMAKE_INSTALL_PREFIX=${workspaceFolder}/install",
            "-DPANDA_ENABLE_RELEASE=OFF",
            "-G",
            "Ninja"
         ],
         "problemMatcher": "$gcc",
         "group": {
            "kind": "build"
         }
      },
      {
         "label": "CMake Build",
         "type": "shell",
         "command": "cmake",
         "args": [
            "--build",
            "build"
         ],
         "problemMatcher": "$gcc",
         "group": {
            "kind": "build"
         }
      },
      {
         "label": "CMake Install",
         "type": "shell",
         "command": "cmake",
         "args": [
            "--install",
            "build"
         ],
         "problemMatcher": "$gcc",
         "group": {
            "kind": "build"
         }
      },
      {
         "label": "CMake Configure Build Install",
         "dependsOrder": "sequence",
         "dependsOn": [
            "CMake Configure Release",
            "CMake Build",
            "CMake Install"
         ],
         "group": {
            "kind": "build",
            "isDefault": true
         }
      }
   ]
}
