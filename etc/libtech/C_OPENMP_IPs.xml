reg started 1INIT_ZERO_VALUE;
reg started_next 1INIT_ZERO_VALUE;
reg done_port_reg 1INIT_ZERO_VALUE;

always @(*) 
begin
  started_next = (started | start_port) &amp; !kmp_bambu_wait_all_threads_rd;
