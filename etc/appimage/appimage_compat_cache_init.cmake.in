set(CMAKE_BUILD_TYPE "@CMAKE_BUILD_TYPE@" CACHE STRING "" FORCE)
set(CMAKE_INSTALL_MESSAGE "@CMAKE_INSTALL_MESSAGE@" CACHE STRING "" FORCE)

set(PANDA_BUILD_BAMBU "@PANDA_BUILD_BAMBU@" CACHE BOOL "" FORCE)
set(PANDA_BUILD_EUCALYPTUS "@PANDA_BUILD_EUCALYPTUS@" CACHE BOOL "" FORCE)
set(PANDA_BUILD_CC "@PANDA_BUILD_CC@" CACHE BOOL "" FORCE)

set(PANDA_ENABLE_RELEASE "@PANDA_ENABLE_RELEASE@" CACHE BOOL "" FORCE)
set(PANDA_ENABLE_ASSERTS "@PANDA_ENABLE_ASSERTS@" CACHE BOOL "" FORCE)
set(PANDA_ENABLE_OPT "@PANDA_ENABLE_OPT@" CACHE BOOL "" FORCE)
set(PANDA_ENABLE_WERROR "@PANDA_ENABLE_WERROR@" CACHE BOOL "" FORCE)
set(PANDA_ENABLE_DEBUG "@PANDA_ENABLE_DEBUG@" CACHE BOOL "" FORCE)
set(PANDA_ENABLE_UNORDERED "@PANDA_ENABLE_UNORDERED@" CACHE BOOL "" FORCE)
set(PANDA_SYNC_PARAMETER_METADATA OFF CACHE BOOL "" FORCE)

set(PANDA_APPIMAGE_NAME "@PANDA_APPIMAGE_NAME@" CACHE STRING "" FORCE)
set(PANDA_APPIMAGE_ROOT "@_compat_appdir_container@" CACHE PATH "" FORCE)
set(PANDA_APPIMAGE_BUILD_ENV "host" CACHE STRING "" FORCE)
set(PANDA_APPIMAGE_CONTAINER_RUNTIME "" CACHE STRING "" FORCE)
set(PANDA_APPIMAGE_CONTAINER_IMAGE "@PANDA_APPIMAGE_CONTAINER_IMAGE@" CACHE STRING "" FORCE)
set(PANDA_APPIMAGE_RUNTIME_FILE "@PANDA_APPIMAGE_RUNTIME_FILE@" CACHE FILEPATH "" FORCE)
set(PANDA_APPIMAGE_MAX_GLIBC "@PANDA_APPIMAGE_MAX_GLIBC@" CACHE STRING "" FORCE)

set(PANDA_APPIMAGE_PARALLEL "@PANDA_APPIMAGE_PARALLEL@" CACHE STRING "" FORCE)
set(PANDA_LIBBAMBU_COMPILER "@PANDA_LIBBAMBU_COMPILER@" CACHE STRING "" FORCE)
set(PANDA_MIN_CLANG_VERSION "@PANDA_MIN_CLANG_VERSION@" CACHE STRING "" FORCE)
set(PANDA_MAX_CLANG_VERSION "@PANDA_MAX_CLANG_VERSION@" CACHE STRING "" FORCE)
set(PANDA_DIST_COMPILERS "@PANDA_DIST_COMPILERS@" CACHE STRING "" FORCE)
set(PANDA_DIST_COMPILERS_BACKUP "@PANDA_DIST_COMPILERS_BACKUP@" CACHE STRING "" FORCE)
